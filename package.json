{
  "name": "@feesfun/extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "BUILD_TARGET=popup vite build --watch --mode development",
    "dev:all": "node scripts/build.js --dev",
    "build": "node scripts/build.js",
    "build:fast": "node scripts/build.js --no-obfuscate",
    "build:popup": "BUILD_TARGET=popup vite build",
    "build:background": "BUILD_TARGET=background vite build",
    "build:content": "BUILD_TARGET=content vite build",
    "clean": "rm -rf dist",
    "publish": "bash scripts/publish.sh"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "@turnkey/crypto": "^2.8.10",
    "@turnkey/sdk-server": "^5.0.3",
    "bs58": "^4.0.1",
    "framer-motion": "^12.34.1",
    "lucide-react": "^0.544.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "javascript-obfuscator": "^5.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
